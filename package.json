{
  "name": "network-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "VITE_APP_RUNTIME=enterprise tsc -b && vite build",
    "build:standalone": "VITE_APP_RUNTIME=standalone tsc -b && vite build",
    "build:enterprise-preview": "VITE_APP_RUNTIME=enterprise tsc -b && vite build",
    "preview": "vite preview",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "test:server": "vitest run tests",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name network-manager --branch main",
    "deploy:pages:enterprise-preview": "npm run build:enterprise-preview && wrangler pages deploy dist --project-name network-manager --branch enterprise-preview",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.5.1",
    "resend": "^6.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
