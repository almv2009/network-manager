VITE_APP_RUNTIME=standalone
APP_BASE_URL=http://127.0.0.1:8788
TENANT_DEFAULT_ID=local
TENANT_CONFIG_JSON=
TENANT_ALLOW_HEADER_OVERRIDE=0
TENANT_HEADER_NAME=x-sgt-tenant-id
TENANT_STRICT_RESOLUTION=0
TENANT_BASE_HOSTS=
TENANT_TRUSTED_CLAIM_HEADER=x-sgt-auth-tenant
TENANT_DEFAULT_AUTH_MODE=local_vendor
TENANT_DEFAULT_DATABASE_MODE=d1
TENANT_DEFAULT_STORAGE_MODE=r2
TENANT_DEFAULT_D1_BINDING=DB
TENANT_DEFAULT_R2_BINDING=DOCUMENTS_BUCKET
TENANT_DEFAULT_EXTERNAL_DB_CONNECTION=
TENANT_DEFAULT_EXTERNAL_STORAGE_CONNECTION=
SESSION_COOKIE_NAME=nm_session
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_HOURS=12
OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_CLIENT_ID=replace-with-client-id
OIDC_CLIENT_SECRET=replace-with-client-secret
OIDC_SCOPES=openid profile email offline_access
OIDC_PROVIDER_NAME=Microsoft Entra External ID
MAIL_FROM_ADDRESS=noreply@ataconsultancy.network
INVITE_EMAIL_SENDER=Safeguarding Together <noreply@ataconsultancy.network>
MAIL_REPLY_TO_ADDRESS=admin@ataconsultancy.net
INVITE_EMAIL_WEBHOOK_URL=
INVITE_EMAIL_WEBHOOK_BEARER_TOKEN=
RESEND_API_KEY=
SUPPORT_EMAIL=admin@ataconsultancy.net
ORGANIZATION_BRANDING_NAME=Network Manager
ORGANIZATION_BRANDING_LOGO_URL=
CASE_CLOSED_SUPERVISOR_ACCESS=0
DOCUMENTS_STORAGE_PROVIDER=r2
DOCUMENT_UPLOAD_MAX_BYTES=10485760
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/webp,text/plain
